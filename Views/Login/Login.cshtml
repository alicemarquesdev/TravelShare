@model LoginModel
@{
    Layout = "_LayoutDeslogado";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header"><h3 class="text-center font-weight-light my-4">Login</h3></div>
                <div class="card-body">
                    <form asp-controller="Login" asp-action="Entrar" method="post">
                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="EmailOuUsername" type="text" />
                            <label for="EmailOuUsername">Email/Username</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.EmailOuUsername)</span>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control"  asp-for="Senha" type="password"/>
                            <label for="Senha">Senha</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.Senha)</span>
                        </div>
                      
                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                            <a class="small" asp-controller="Login" asp-action="RedefinirSenha">Esqueceu a Senha?</a>
                            <button type="submit" class="btn btn-dark">Login</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a asp-controller="Login" asp-action="CriarConta">Não tem uma conta? Crie uma conta!</a></div>
                </div>
            </div>
        </div>
    </div>
</div>