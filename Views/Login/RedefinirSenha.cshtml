@{
    Layout = "_LayoutDeslogado";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header"><h3 class="text-center font-weight-light my-4">Redefinir Senha</h3></div>
                <div class="card-body">
                    <div class="small mb-3 text-muted">
                        Digite seu endereço de e-mail e nós enviaremos um link para redefinir sua senha.
                    </div>
                    <form>
                        <div class="form-floating mb-3">
                            <input class="form-control" id="Email" type="email" />
                            <label for="inputEmail">Digite seu Email</label>
                        </div>
                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                            <a class="small" asp-controller="Login" asp-action="Login">Efetuar Login.</a>
                            <a class="btn btn-dark" href="login.html">Enviar</a>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a asp-controller="Login" asp-action="CriarConta">Não tem uma conta? Crie uma conta!</a></div>
                </div>
            </div>
        </div>
    </div>
</div>