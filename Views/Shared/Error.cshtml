@model ErrorViewModel
@{
    ViewData["Title"] = "Ocorreu um Erro";
}

<div class="container text-center mt-5">
    <h1 class="text-danger">Oops! Algo deu errado.</h1>
    <p class="lead">Não conseguimos processar sua solicitação no momento.</p>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Voltar para a Página Inicial</a>
    </div>

    <div class="mt-5 text-muted">
        <small>Se o problema persistir, entre em contato com o suporte.</small>
    </div>
</div>
