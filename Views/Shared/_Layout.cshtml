<!DOCTYPE html>
<html lang="pt-br" class="p-0 m-0">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>TravelShare</title>

    <!-- Font Awesome icons (free version) -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Saira+Extra+Condensed:500,700" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Muli:400,400i,800,800i" rel="stylesheet" type="text/css" />

    <!-- Bootstrap Icons CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- jQuery UI CSS -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">

    <!-- Core theme CSS (includes Bootstrap) -->
    <link href="~/css/styles.css" rel="stylesheet" />
</head>
<body id="page-top">
    <!-- Navigation -->
    @await Component.InvokeAsync("Menu")

    <main role="main" class="bg-white p-0 m-0">
        <div class="m-5">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-dark mt-3" role="alert">
                    <button type="button" class="btn btn-dark btn-sm close-alert rounded-5" data-bs-dismiss="alert" aria-label="Close">X</button>
                    @TempData["Message"]
                </div>
            }
        </div>
        @RenderBody()
    </main>

    <!-- jQuery (sempre antes do Bootstrap JS) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- jQuery UI -->
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>

    <!-- Bootstrap JS Bundle (inclui o Popper.js) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDm12Mf116MlgdKgdAUPzDwqpDrjTudYpc&libraries=places&callback=initGoogleMaps"></script>
    <script src="~/js/googleApi.js"></script>
    <script src="~/js/scripts.js"></script>
    <script src="~/js/comentario.js"></script>
    <script src="~/js/cidadesVisitadas.js"></script>
    <script src="~/js/seguidor.js"></script>
    <script src="~/js/curtida.js"></script>
    <script src="~/js/barraDePesquisa.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
