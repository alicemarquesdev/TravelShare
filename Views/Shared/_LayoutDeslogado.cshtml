<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>TravelShare</title>

    <!-- Font Awesome icons -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

    <!-- Estilo personalizado para layout deslogado -->
    <link href="~/css-deslogado/styles.css" rel="stylesheet" />
</head>
<body class="bg-white">
    <nav class="navbar bg-dark fixed-top mb-lg-5" style="height: 60px; padding: 0 20px;">
        <h3 class="text-white text-start py-3 ms-5">TravelShare</h3>
    </nav>
    <div id="layoutAuthentication">
        <div id="layoutAuthentication_content">
            <main class="mt-5">
                <div class="container mt-5 pt-2">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-dark mt-3" role="alert">
                            <button type="button" class="btn btn-dark btn-sm close-alert rounded-5" data-bs-dismiss="alert" aria-label="Close">X</button>
                            @TempData["Message"]
                        </div>
                    }
                </div>
                @RenderBody()
            </main>
        </div>
        <div id="layoutAuthentication_footer">
            <footer class="py-4 bg-dark mt-auto">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">Copyright &copy; TravelShare 2025</div>
                        <div>
                            <a class="text-secondary" href="#">Privacy Policy</a>
                            &middot;
                            <a class="text-secondary" href="#">Terms &amp; Conditions</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Bootstrap JS Bundle (inclui o Popper.js) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- jQuery Validation -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>


    <!-- Google Maps API e Places API -->

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDm12Mf116MlgdKgdAUPzDwqpDrjTudYpc&libraries=places&callback=initAutocomplete" async defer></script>

    <script src="~/js-deslogado/scripts.js"></script>
</body>
</html>
