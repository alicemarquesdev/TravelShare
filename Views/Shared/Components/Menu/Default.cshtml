@model UsuarioModel

<nav class="navbar navbar-expand-lg bg-white fixed-left" id="sideNav" style="border-right: 3px solid black; height: 100vh; width: 250px; padding-top: 20px; display: flex; flex-direction: column;">

    <!-- Título TravelShare fixado no topo -->
    <h3 class="text-dark text-center mb-4">TravelShare</h3>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Lista centralizada verticalmente -->
    <div class="collapse navbar-collapse" id="navbarResponsive" style="flex-grow: 1; display: flex; align-items: center; justify-content: center;">
        <ul class="navbar-nav flex-column align-items-start ms-4">
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door fs-5"></i> Página Inicial
                </a>
            </li>
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" asp-controller="Home" asp-action="Pesquisar" asp-route-id="@Model.Id">
                    <i class="bi bi-search fs-5"></i> Pesquisa
                </a>
            </li>
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" asp-controller="Home" asp-action="Explorar" asp-route-id="@Model.Id">
                    <i class="bi bi-compass fs-5"></i> Explorar
                </a>
            </li>
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" href="#skills">
                    <i class="bi bi-bell fs-5"></i> Notificações
                </a>
            </li>
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" asp-controller="Posts" asp-action="CriarPost" asp-route-id="@Model.Id">
                    <i class="bi bi-plus-circle fs-5"></i> Criar
                </a>
            </li>
            <li class="nav-item mb-4">
                <a class="nav-link js-scroll-trigger" asp-controller="Usuario" asp-action="Perfil" asp-route-id="@Model.Id">
                    <img src="@Url.Content(Model.FotoPerfil)" alt="Foto de Perfil" class="rounded-circle" style="width: 25px; height: 25px; object-fit: cover;">
                    @Model.Nome
                </a>
            </li>
        </ul>
    </div>
  
    <div class="d-flex align-items-center justify-items-center w-100 mb-5 ms-5">
        <!-- Dropdown para abrir para cima e à direita -->
        <div class="dropup-center dropup">
            <a class="text-decoration-none fw-bold text-secondary d-flex align-items-center" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-list fs-4"></i>
                <span class="ms-2 fs-5">MAIS</span>
            </a>

            <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink" style="bottom: 100%; top: auto;">
                <li><a class="dropdown-item fw-bold text-secondary" asp-controller="Usuario" asp-action="EditarPerfil" asp-route-id="@Model.Id">Editar Perfil</a></li>
                <li><a class="dropdown-item fw-bold text-secondary" asp-controller="PaisesVisitados" asp-action="EditarMapa" asp-route-id="@Model.Id">Editar Mapa</a></li>
                <li><a class="dropdown-item fw-bold text-secondary" asp-controller="Login" asp-action="Sair">Sair</a></li>
            </ul>
        </div>
    </div>

</nav>
