@using TravelShare.Helper
@model UsuarioModel

@{
    var posts = ViewBag.PostsDoUsuario as List<PostsModel>;
    var usuarioLogadoId = ViewBag.UsuarioLogado as string;
}

<div class="container mt-3">
    <div class="d-flex mb-4 position-relative">
        <!-- Foto de Perfil -->
        <div class="me-5 ms-5">
            <img src="@Url.Content(Model.FotoPerfil)" class="rounded-circle img-fluid border border-4 border-seondary" alt="Foto do Perfil" style="width: 200px; height: 200px; object-fit: cover;">
        </div>

        <!-- Informações do Usuário -->
        <div class="mb-2">
            <div class="d-flex align-items-start mb-1 px-0">
                <!-- Nome do Usuário -->
                <h2 class="mb-0 p-0">@Model.Nome</h2>
            </div>

            <p class="fw-bold mb-2">@@@Model.Username</p>

            <div class="d-flex gap-4 mb-2">
                <span><strong>@posts.Count</strong> posts</span>
                <a class="text-decoration-none text-secondary" asp-controller="Usuario" asp-action="Seguidores" asp-route-id="@Model.Id"><strong>@Model.Seguidores.Count</strong> seguidores</a>
                <a class="text-decoration-none text-secondary" asp-controller="Usuario" asp-action="Seguindo" asp-route-id="@Model.Id"><strong>@Model.Seguindo.Count</strong> seguindo</a>
            </div>
            <p class="fw-bold mb-2">@Model.PaisNascimento</p>
            <p class="fw-bold mb-2">@Model.Bio</p>
        </div>

        @if (usuarioLogadoId == Model.Id.ToString())
        {
            <!-- Botões no canto superior direito -->
            <div class="position-absolute top-0 end-0 mt-3 me-2 d-flex">
                <a class="btn btn-outline-secondary" asp-controller="Usuario" asp-action="EditarPerfil" asp-route-id="@Model.Id">
                    <i class="bi bi-pencil p-1"> Perfil</i>
                </a>
            </div>
        }
        else
        {
            <div class="d-flex mt-3 ms-5">
                <form asp-controller="Seguidor" asp-action="SeguirEDeseguir" method="post">
                    <input type="hidden" name="seguindoId" value="@Model.Id.ToString()" />
                    <input type="hidden" name="usuarioId" value="@usuarioLogadoId" />
                    @if (Model.Seguidores != null && Model.Seguidores.Contains(usuarioLogadoId))
                    {
                        <button type="submit" class="btn btn-secondary"> Seguindo </button>

                    }
                    else if (Model.Seguindo != null & Model.Seguindo.Contains(usuarioLogadoId))
                    {
                        <button type="submit" class="btn btn-primary"> Seguir de volta </button>

                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger"> Seguir </button>
                    }
                </form>
            </div>
        }
    </div>


    <!-- Botão para alternar a exibição do Mapa -->
    <div class="border-top border-dark pb-3 text-center gap-4">
        <button class="btn" id="postsButton" onclick="toggleSection('postsSection')">
            <i class="bi bi-grid-3x3-gap-fill" style="font-size: 1.2rem; color: #6c757d;"></i>
            Publicações
        </button>
        <button class="btn" id="mapButton" onclick="toggleSection('mapSection')">
            <i class="bi bi-map" style="font-size: 1.2rem; color: #6c757d;"></i>
            Mapa
        </button>
    </div>

    <!-- Mapa -->
    <div class="container mt-1 mb-5" id="mapSection" style="display:none;">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8">
                <div id="map" style="height: 400px; width: 100%;"></div>
            </div>
        </div>
    </div>

    <!-- Feed de Posts -->
    <div class="row g-3 pb-5 mx-3" id="postsSection">
        @if (posts != null && posts.Any())
        {
            foreach (var post in posts)
            {
                <div class="col-6 col-md-4">
                    <div class="position-relative">
                        <img src="@Url.Content(post.FotoPost.FirstOrDefault() ?? "/images/default.png")"
                             class="img-fluid rounded post-thumbnail"
                             alt="Imagem do Post"
                             style="object-fit: cover; width: 100%; height: 350px;"
                             data-bs-toggle="modal"
                             data-bs-target="#postModal_@post.Id">
                    </div>
                </div>

                <!-- Modal do Post -->
                <div class="modal fade" id="postModal_@post.Id" tabindex="-1" aria-labelledby="postModalLabel_@post.Id" aria-hidden="true">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-body p-0">
                                <div class="row g-0">
                                    <!-- Carrossel de Imagens -->
                                    <div class="col-md-7">
                                        <div id="carouselPostImages_@post.Id" class="carousel slide h-100" data-bs-ride="carousel">
                                            <div class="carousel-inner h-100">
                                                @foreach (var foto in post.FotoPost)
                                                {
                                                    <div class="carousel-item @(foto == post.FotoPost.First() ? "active" : "") h-100">
                                                        <img src="@Url.Content(foto)" class="d-block w-100 h-100" alt="Imagem do Post" style="object-fit: cover;">
                                                    </div>
                                                }
                                            </div>
                                            <button class="carousel-control-prev" type="button" data-bs-target="#carouselPostImages_@post.Id" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Anterior</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target="#carouselPostImages_@post.Id" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Próximo</span>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Informações do Post -->
                                    <div class="col-md-5 d-flex flex-column">
                                        <!-- Header do Post -->
                                        <div class="d-flex align-items-center border-bottom p-3">
                                            <img src="@Url.Content(Model.FotoPerfil)" alt="Foto de Perfil" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                            <h6 class="ms-2 mb-0 fw-bold">@Model.Nome</h6>
                                            @if (Model.Id == usuarioLogadoId)
                                            {
                                                <a class="btn btn-outline-secondary btn-sm ms-auto" asp-controller="Posts" asp-action="EditarPost" asp-route-id="@post.Id"><i class="bi bi-pencil"> Editar</i></a>

                                            }
                                            <p class="mb-1">@post.Localizacao</p>
                                            <p class="mb-0 text-muted ms-auto">@post.DataCriacao?.TempoDecorridoPost()</p>
                                        </div>

                                        <!-- Legenda e Comentários -->
                                        <div class="flex-grow-1 p-3 overflow-auto">
                                            <!-- Legenda -->
                                            <div>
                                                <p class="mb-1"><strong>@@@Model.Username</strong> @post.Legenda</p>
                                            </div>

                                            <!-- Comentários -->
                                            <div class="mt-3">
                                                @if (post.Comentarios.Any())
                                                {
                                                    foreach (var comentario in post.Comentarios)
                                                    {
                                                        <div class="mb-2">
                                                            <p class="mb-0"><strong>@comentario.UsuarioUsername</strong> @comentario.Comentario</p>

                                                            @if (usuarioLogadoId == Model.Id.ToString() || comentario.UsuarioId == usuarioLogadoId)
                                                            {
                                                                <form asp-controller="Comentario" asp-action="DeletarComentario" method="post">
                                                                    <input type="hidden" name="id" value="@comentario.Id" />
                                                                    <button type="submit" class="btn"> <i class="bi bi-trash"></i></button>
                                                                </form>
                                                            }

                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <p class="text-muted">Nenhum comentário ainda.</p>
                                                }
                                            </div>
                                        </div>

                                        <!-- Área de Interações -->
                                        <div class="border-top p-3">
                                            <!-- Botão de Curtida -->
                                            <div class="d-flex align-items-center mb-2">
                                                <form asp-controller="Curtida" asp-action="CurtirEDescurtir" method="post">
                                                    <input type="hidden" name="postId" value="@post.Id" />
                                                    <input type="hidden" name="usuarioId" value="@Model.Id" />

                                                    <button type="submit" class="btn p-0 @(post.Curtidas != null && post.Curtidas.Contains(Model.Id) ? "text-danger" : "text-dark")">
                                                        <i class="bi @(post.Curtidas != null && post.Curtidas.Contains(Model.Id) ? "bi-heart-fill fs-4" : "bi-heart fs-5")"></i>
                                                    </button>
                                                </form>

                                                <span class="ms-2">@post.Curtidas?.Count curtidas</span>
                                            </div>

                                            <!-- Formulário de Adicionar Comentário -->
                                            <form asp-controller="Comentario" asp-action="AddComentario" method="post" class="d-flex">
                                                <input type="hidden" name="PostId" value="@post.Id" />
                                                <input type="hidden" name="UsuarioId" value="@Model.Id" />
                                                <div class="input-group">
                                                    <i class="bi bi-chat input-group-text"></i>
                                                    <input type="text" name="Comentario" class="form-control me-2" placeholder="Adicionar um comentário..." required />
                                                    <button type="submit" class="btn">Publicar</button>
                                                </div>
                                            </form>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-muted">Ainda não há posts para mostrar.</p>
            </div>
        }
    </div>
    
</div>

<!-- Script do Google Maps -->
<script>
    let map;

    function initMap() {
        map = new google.maps.Map(document.getElementById("map"), {
            center: { lat: -14.2350, lng: -51.9253 }, // Centro do Brasil
            zoom: 3
        });

        // Lista de países visitados do usuário (contém apenas nomes dos países)
        const paisesVisitados = @Html.Raw(Json.Serialize(ViewBag.PaisesVisitados));

        if (paisesVisitados && paisesVisitados.length > 0) {
            const geocoder = new google.maps.Geocoder();

            paisesVisitados.forEach(pais => {
                // Geocodificando o nome do país para latitude e longitude
                geocoder.geocode({ 'address': pais }, function (results, status) {
                    if (status === 'OK') {
                        const latitude = results[0].geometry.location.lat();
                        const longitude = results[0].geometry.location.lng();

                        // Criando um marcador no mapa para o país geocodificado
                        new google.maps.Marker({
                            position: { lat: latitude, lng: longitude },
                            map,
                            title: pais
                        });
                    } else {
                        console.log('Geocoding failed for the following reason: ' + status);
                    }
                });
            });
        }
    }

    function toggleSection(sectionId) {
        document.getElementById('mapSection').style.display = 'none';
        document.getElementById('postsSection').style.display = 'none';
        document.getElementById(sectionId).style.display = 'block';

        if (sectionId === 'mapSection' && map) {
            google.maps.event.trigger(map, 'resize');
        }
    }
</script>

