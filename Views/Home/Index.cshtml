@using TravelShare.Helper
@model List<PostsModel>

@{
    var sugestoes = ViewBag.SugestoesParaSeguir as List<UsuarioModel>;
    var usuarioLogado = ViewBag.UsuarioLogado as UsuarioModel;
}

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <!-- Coluna de posts -->
        <div class="col-12 col-md-8">
            @if (Model != null && Model.Any())
            {
                foreach (var post in Model)
                {
                    <div class="card mx-auto mb-4" style="max-width: 600px;">
                        <!-- Cabeçalho do Post -->
                        <div class="card-header d-flex align-items-center">
                            <a class="text-decoration-none text-secondary d-flex align-items-center" asp-controller="Usuario" asp-action="Perfil" asp-route-id="@post.Usuario.Id">
                                <img src="@Url.Content(post.Usuario?.FotoPerfil)" alt="User" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;">
                                <div class="ms-2">
                                    <p class="mb-0"><strong>@post.Usuario?.Nome</strong></p>
                                </div>
                            </a>
                            <p class="mb-1">@post.Localizacao</p>
                            <p class="mb-0 text-muted ms-auto">@post.DataCriacao?.TempoDecorridoPost()</p>
                        </div>

                        <!-- Carrossel de Imagens -->
                        <div id="carouselExampleIndicators_@post.Id" class="carousel slide" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                @foreach (var foto in post.FotoPost.Select((foto, index) => new { foto, index }))
                                {
                                    <div class="carousel-item @(foto.index == 0 ? "active" : "")">
                                        <img src="@Url.Content(foto.foto)" class="d-block w-100" alt="Imagem @foto.index">
                                    </div>
                                }
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators_@post.Id" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators_@post.Id" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>

                        <!-- Corpo do Post -->
                        <div class="border-top p-3">
                            <!-- Botão de Curtida -->
                            <div class="d-flex align-items-center mb-2">
                                <form asp-controller="Curtida" asp-action="CurtirEDescurtir" method="post">
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="usuarioId" value="@usuarioLogado.Id" />

                                    <button type="submit" class="btn p-0 @(post.Curtidas != null && post.Curtidas.Contains(post.Usuario.Id) ? "text-danger" : "text-dark")">
                                        <i class="bi @(post.Curtidas != null && post.Curtidas.Contains(post.Usuario.Id) ? "bi-heart-fill fs-4" : "bi-heart fs-5")"></i>
                                    </button>
                                </form>

                                <span class="ms-2">@post.Curtidas?.Count curtidas</span>
                            </div>

                            <!-- Área de Comentários -->
                            <div class="card-footer">
                                <p><strong>@post.Usuario?.Username</strong> @post.Legenda</p>
                                <div class="mt-3">
                                    @if (post.Comentarios != null && post.Comentarios.Any())
                                    {
                                        @foreach (var comentario in post.Comentarios)
                                        {
                                            <div class="mb-2 d-flex align-items-center">
                                                <p class="mb-0"><strong>@comentario.UsuarioUsername</strong> @comentario.Comentario</p>
                                                @if (usuarioLogado.Id == post.UsuarioId.ToString() || comentario.UsuarioId == usuarioLogado.Id)
                                                {
                                                    <form asp-controller="Comentario" asp-action="DeletarComentario" method="post">
                                                        <input type="hidden" name="id" value="@comentario.Id" />
                                                        <button type="submit" class="btn"> <i class="bi bi-trash"></i></button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Formulário de Adicionar Comentário -->
                            <form asp-controller="Comentario" asp-action="AddComentario" method="post" class="d-flex">
                                <input type="hidden" name="PostId" value="@post.Id" />
                                <input type="hidden" name="UsuarioId" value="@usuarioLogado.Id" />
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-chat"></i></span>
                                    <input type="text" name="Comentario" class="form-control" placeholder="Adicionar um comentário..." required />
                                    <button type="submit" class="btn btn-primary">Publicar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-center">Nenhum post publicado.</p>
            }
        </div>

        <!-- Coluna de Sugestões -->
        <div class="col-12 col-md-4">
            <div class="card" style="position: sticky; top: 0; z-index: 100;">
                <!-- Header de Sugestões -->
                <div class="card-header">
                    <h5>Sugestões para seguir</h5>
                </div>
                <ul class="list-group">

                    @if (sugestoes.Any())
                    {
                        foreach (var sugestao in sugestoes.Take(6))
                        {
                            <li class="list-group-item d-flex align-items-center">
                                <a class="text-decoration-none text-secondary d-flex align-items-center" asp-controller="Usuario" asp-action="Perfil" asp-route-id="@sugestao.Id">
                                    <img src="@Url.Content(sugestao.FotoPerfil)" alt="User" class="rounded-circle" width="30" height="30">
                                    <div class="ms-2">
                                        <p class="mb-0"><strong>@sugestao.Nome</strong></p>
                                    </div>
                                </a>
                                <div class="ms-auto">
                                    <form asp-controller="Seguidor" asp-action="SeguirEDeseguir" method="post">
                                        <input type="hidden" name="seguindoId" value="@sugestao.Id.ToString()" />
                                        <input type="hidden" name="usuarioId" value="@usuarioLogado.Id" />
                                        @if (usuarioLogado.Seguidores != null & usuarioLogado.Seguidores.Contains(sugestao.Id.ToString()))
                                        {
                                            <button type="submit" class="btn btn-dark btn-sm ms-auto"> Seguir de volta </button>

                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-dark btn-sm ms-auto"> Seguir </button>
                                        }
                                    </form>
                                </div>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item">Nenhuma sugestão disponível.</li>
                    }

                </ul>
            </div>
        </div>
    </div>
</div>
