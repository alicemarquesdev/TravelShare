@{
    ViewData["Title"] = "";
}

<div class="container mt-5">
    <!-- Perfil do Usuário -->
    <div class="row align-items-center mb-4">
        <!-- Foto do Perfil -->
        <div class="col-md-3 text-center">
            <img src="https://via.placeholder.com/150" class="rounded-circle img-fluid" alt="Foto do Perfil">
        </div>
        <!-- Informações do Usuário -->
        <div class="col-md-6">
            <h3>@Model.UserName</h3>
            <div class="d-flex align-items-center gap-3 mt-2">
                <button class="btn btn-primary">Seguir</button>
                <button class="btn btn-outline-secondary">Message</button>
            </div>
            <div class="mt-3">
                <span><strong>@Model.PostCount</strong> posts</span>
                <span class="mx-3"><strong>@Model.FollowerCount</strong> seguidores</span>
                <span><strong>@Model.FollowingCount</strong> seguindo</span>
            </div>
        </div>
        <!-- Bio -->
        <div class="col-md-3">
            <p class="text-muted">@Model.Bio</p>
        </div>
    </div>

    <!-- Feed de Posts -->
    <div class="row g-3">
        @foreach (var post in Model.Posts)
        {
            <div class="col-md-4">
                <div class="position-relative">
                    <img src="@post.ImageUrl" class="img-fluid rounded" alt="Post Image">
                    <!-- Número de likes e comentários (opcional) -->
                    <div class="position-absolute bottom-0 start-0 bg-dark bg-opacity-50 text-white p-2 w-100">
                        <span class="me-2"><i class="bi bi-heart-fill"></i> @post.Likes</span>
                        <span><i class="bi bi-chat-fill"></i> @post.Comments</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
