@model AlterarSenhaModel

@{
    var usuarioId = ViewBag.UsuarioId as string;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header"><h3 class="text-center font-weight-light my-4">Alterar Senha</h3></div>
                <div class="card-body">
                    <form asp-controller="AlterarSenha" asp-action="AlterarSenha" method="post">

                        <input type="hidden" asp-for="Id" value="@usuarioId" />

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="SenhaAtual" type="password" />
                            <label for="SenhaAtual">Senha Atual</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.SenhaAtual)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="NovaSenha" type="password" id="Senha" />
                            <label for="NovaSenha">Nova Senha</label>
                            <span id="senhaErro" class="text-danger">@Html.ValidationMessageFor(x => x.NovaSenha)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="NovaSenhaConfirmacao" type="password" />
                            <label for="NovaSenhaConfirmacao">Confirmar Nova Senha</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.NovaSenhaConfirmacao)</span>
                        </div>

                        <div class="d-flex justify-content-end mt-4 mb-0">
                            <button type="submit" class="btn btn-dark">Alterar Senha</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a class="text-dark" asp-controller="Usuario" asp-action="EditarPerfil" asp-route-id="@Model.Id">Voltar</a></div>
                </div>
            </div>
        </div>
    </div>
</div>
